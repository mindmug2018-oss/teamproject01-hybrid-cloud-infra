global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 5s
  group_interval: 30s
  repeat_interval: 5m
  receiver: 'slack-default'
  routes:
    - match:
        severity: critical
      receiver: 'slack-and-recovery'
      continue: true
    - match:
        severity: critical
      receiver: 'telegram'
    - match:
        severity: warning
      receiver: 'slack-default'
      continue: true          # ← add continue: true
    - match:
        severity: warning
      receiver: 'telegram'

receivers:
  - name: 'telegram'
    webhook_configs:
      - url: 'http://localhost:9087/alert/8646527871'
        send_resolved: true

  - name: 'slack-default'
    slack_configs:
      - api_url: '{{ slack_webhook_url }}'   # Ansible will replace this correctly
        channel: '#all-mindmug'
        send_resolved: true
        # Wrap Go templates in {% raw %} tags below:
        title: '{% raw %}[{{ .Status | toUpper }}] {{ .GroupLabels.alertname }}{% endraw %}'
        text: '{% raw %}{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}{% endraw %}'

  - name: 'slack-and-recovery'
    slack_configs:
      - api_url: '{{ slack_webhook_url }}'   # Ansible will replace this correctly
        channel: '#all-mindmug'
        send_resolved: true
        title: '{% raw %}[CRITICAL] {{ .GroupLabels.alertname }}{% endraw %}'
        text: '{% raw %}{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}{% endraw %}'
    webhook_configs:
      - url: 'http://localhost:9080/alert'
        send_resolved: false